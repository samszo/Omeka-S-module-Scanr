        $eurs = [
            ['id' => 'arts',        'label' => 'Arts, créations, technologies & industries culturelles',                               'icon' => '🎨'],
            ['id' => 'transitions', 'label' => 'Transitions numériques, écologiques & économiques',                                    'icon' => '🌱'],
