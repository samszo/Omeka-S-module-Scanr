    </div>
<?php else: ?>

    <div class="scanr-eur-header">
        <h2 class="scanr-eur-title"><?php echo $escape($heading); ?></h2>
        <div class="scanr-eur-toolbar">
            <button id="scanr-eur-btn-evaluate" class="scanr-btn scanr-btn-primary">
                Evaluer les convergences
            </button>
            <span class="scanr-eur-researchers-count" id="scanr-eur-count"></span>
        </div>
    </div>

    <div class="scanr-eur-legend">
        Un agent expert en pilotage de la science analyse les mots-clefs, publications et co-auteurs
        de chaque chercheur [<em>valo:EnseignantChercheur</em>] et évalue la convergence avec chacune des EUR.
    </div>

    <div id="scanr-eur-loading" class="scanr-loading" style="display:none">
