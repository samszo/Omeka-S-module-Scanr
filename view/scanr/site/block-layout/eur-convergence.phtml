<?php
/**
 * Block layout "Convergences EUR Scanr".
 *
 * @var string  $heading
 * @var bool    $allowed
 * @var string  $itemsJson   JSON array [{id, title}, …]
 * @var int     $maxPerEur
 * @var string  $ajaxUrl
 */
$escape   = $this->plugin('escapeHtml');
$assetUrl = $this->plugin('assetUrl');
?>

<?php $this->headLink()->appendStylesheet($assetUrl('css/scanr.css', 'Scanr')); ?>

<div id="scanr-toasts"></div>

<div id="scanr-eur-block">

<?php if (!$allowed): ?>
    <div class="scanr-eur-denied">
        <p>Vous devez être <strong>connecté</strong> pour accéder à l'évaluation des convergences EUR.</p>
    </div>
<?php else: ?>

    <div class="scanr-eur-header">
        <h2 class="scanr-eur-title"><?php echo $escape($heading); ?></h2>
        <div class="scanr-eur-toolbar">
            <button id="scanr-eur-btn-evaluate" class="scanr-btn scanr-btn-primary">
                Evaluer les convergences
            </button>
            <span class="scanr-eur-researchers-count" id="scanr-eur-count"></span>
        </div>
    </div>

    <div class="scanr-eur-legend">
        Un agent expert en pilotage de la science analyse les mots-clefs, publications et co-auteurs
        de chaque chercheur [<em>valo:EnseignantChercheur</em>] et évalue la convergence avec chacune des EUR.
    </div>

    <div id="scanr-eur-loading" class="scanr-loading" style="display:none">
        <div class="scanr-spinner"></div>
        <p>L'agent analyse les convergences…</p>
    </div>

    <div id="scanr-eur-error" class="scanr-eur-error" style="display:none"></div>

    <div id="scanr-eur-scale" class="scanr-eur-scale">
        <canvas id="scanr-eur-scale-canvas" class="scanr-eur-scale-canvas" height="20"></canvas>
        <div id="scanr-eur-scale-ticks" class="scanr-eur-scale-ticks"></div>
    </div>

    <div id="scanr-eur-grid" class="scanr-eur-grid">

    </div>

<?php endif; ?>
</div>

<?php if ($allowed): ?>
<?php $this->headScript()->appendFile($assetUrl('js/d3.min.js', 'Scanr'), 'text/javascript', ['defer' => 'defer']); ?>
<script>
const EUR_AJAX_URL  = <?php echo json_encode($ajaxUrl); ?>;
const EUR_ITEMS     = <?php echo $itemsJson; ?>;
const EUR_MAX       = <?php echo (int) $maxPerEur; ?>;
const EUR_IDS       = ['arts', 'transitions', 'care', 'democratie'];
</script>
<?php $this->headScript()->appendFile($assetUrl('js/scanr-eur.js', 'Scanr'), 'text/javascript', ['defer' => 'defer']); ?>
<?php endif; ?>
