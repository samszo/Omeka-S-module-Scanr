            ['id' => 'democratie',  'label' => 'Enjeux démocratiques contemporains, politiques publiques, risques géopolitiques',      'icon' => '🏛️'],
        ];
        foreach ($eurs as $eur):
        ?>
        <div class="scanr-eur-col" id="scanr-eur-col-<?php echo $escape($eur['id']); ?>">
            <div class="scanr-eur-col-header">
                <span class="scanr-eur-icon"><?php echo $eur['icon']; ?></span>
                <span class="scanr-eur-col-title"><?php echo $escape($eur['label']); ?></span>
