            <div class="scanr-eur-col-body" id="scanr-eur-body-<?php echo $escape($eur['id']); ?>">
                <p class="scanr-eur-placeholder">Cliquez sur « Evaluer » pour lancer l'analyse.</p>
            </div>
        </div>
        <?php endforeach; ?>

    </div>

<?php endif; ?>
</div>

<?php if ($allowed): ?>
<script>
const EUR_AJAX_URL  = <?php echo json_encode($ajaxUrl); ?>;
const EUR_ITEMS     = <?php echo $itemsJson; ?>;
const EUR_MAX       = <?php echo (int) $maxPerEur; ?>;
const EUR_IDS       = ['arts', 'transitions', 'care', 'democratie'];
</script>
<?php $this->headScript()->appendFile($assetUrl('js/scanr-eur.js', 'Scanr'), 'text/javascript', ['defer' => 'defer']); ?>
