<script>
const AJAX_URL   = <?php echo json_encode($ajaxUrl); ?>;
const ITEMS_DATA = <?php echo $itemsJson; ?>;

// Mise à jour dynamique par l'autocomplétion, lue par scanr.js
let ITEM_ID = 0,
    allowed = <?php echo $allowed ? 1 : 0; ?>;

(function () {

    const input       = document.getElementById('scanr-person-input');
    const suggestions = document.getElementById('scanr-person-suggestions');
    const panel       = document.getElementById('scanr-expertises');
    const nameSpan    = document.getElementById('scanr-person-name');

    function filterItems(term) {
        const lower = term.toLowerCase();
        return ITEMS_DATA.filter(function (item) {
            return item.title.toLowerCase().includes(lower);
        }).slice(0, 10);
    }

    function renderSuggestions(items) {
        suggestions.innerHTML = '';
        if (!items.length) {
            suggestions.hidden = true;
            return;
        }
        items.forEach(function (item) {
            const li = document.createElement('li');
            li.setAttribute('role', 'option');
            li.textContent   = item.title || '(sans titre)';
            li.dataset.id    = item.id;
            li.dataset.title = li.textContent;
            li.addEventListener('mousedown', function (e) {
                e.preventDefault();
                selectPerson(item.id, li.dataset.title);
            });
            suggestions.appendChild(li);
        });
        suggestions.hidden = false;
    }

    function selectPerson(id, title) {
        ITEM_ID = parseInt(id, 10);
        input.value = title;
        suggestions.hidden = true;

        nameSpan.textContent = title;
        panel.style.display  = '';

        document.getElementById('scanr-kw-grid').innerHTML      = '';
        document.getElementById('scanr-loading').style.display  = '';
        document.getElementById('scanr-empty').style.display    = 'none';
        document.getElementById('scanr-filter-bar').style.display = 'none';

        if (typeof loadExpertises === 'function') {
            loadExpertises();
        }
    }

    input.addEventListener('input', function () {
        const term = input.value.trim();
        if (term.length < 2) { suggestions.hidden = true; return; }
        renderSuggestions(filterItems(term));
    });

    input.addEventListener('blur', function () {
        setTimeout(function () { suggestions.hidden = true; }, 150);
    });

    input.addEventListener('keydown', function (e) {
        const liItems = suggestions.querySelectorAll('li');
        const active  = suggestions.querySelector('li.scanr-active');
        if (e.key === 'ArrowDown') {
            e.preventDefault();
            const next = active ? active.nextElementSibling : liItems[0];
            if (active) active.classList.remove('scanr-active');
            if (next) next.classList.add('scanr-active');
        } else if (e.key === 'ArrowUp') {
            e.preventDefault();
            const prev = active ? active.previousElementSibling : liItems[liItems.length - 1];
            if (active) active.classList.remove('scanr-active');
            if (prev) prev.classList.add('scanr-active');
        } else if (e.key === 'Enter' && active) {
            e.preventDefault();
            selectPerson(active.dataset.id, active.dataset.title);
        } else if (e.key === 'Escape') {
            suggestions.hidden = true;
        }
    });
}());
</script>
<?php $this->headScript()->appendFile($assetUrl('js/scanr.js', 'Scanr'), 'text/javascript', ['defer' => 'defer']); ?>
