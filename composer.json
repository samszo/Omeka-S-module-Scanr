{
    "name": "samszo/omeka-s-module-scanr",
    "description": "Omeka S module for managing seach person in scanr database",
    "type": "omeka-s-module",
    "license": "MIT",
    "authors": [
        {
            "name": "Samuel Szoniecky",
            "email": "samuel.szoniecky@univ-paris8.fr"
        }
    ],
    "keywords": [
        "omeka",
        "omeka-s",
        "elasticsearch",
        "scanr"
    ],
    "require": {
        "php": "^7.4 || ^8.0",
        "elasticsearch/elasticsearch": "^8.18",       
        "satur.io/duckdb":"2.1.0"
    },
    "autoload": {
        "psr-4": {
            "Scanr\\": "src/"
        }
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true
        }
    },
    "scripts": {
        "post-install-cmd": "\\Saturio\\DuckDB\\CLib\\Installer::install",
        "post-update-cmd": "\\Saturio\\DuckDB\\CLib\\Installer::install"
    }
}
